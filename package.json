{
	"name": "soon",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"check-types": "turbo run check-types",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "turbo run test",
		"test:watch": "vitest --watch"
	},
	"devDependencies": {
		"@repo/vitest-config": "*",
		"@trivago/prettier-plugin-sort-imports": "6.0.2",
		"oxlint": "1.65.0",
		"prettier": "3.8.3",
		"prettier-plugin-tailwindcss": "0.8.0",
		"turbo": "2.9.14",
		"typescript": "6.0.3",
		"vite": "8.0.13",
		"vitest": "4.1.6"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.6",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"overrides": {
		"better-auth": "1.6.11",
		"@better-auth/core": "1.6.11",
		"vite": "8.0.13"
	}
}
